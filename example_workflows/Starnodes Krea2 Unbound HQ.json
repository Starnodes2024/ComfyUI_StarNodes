      "properties": {
        "Node name for S&R": "Note"
      },
      "widgets_values": [
        "**ℹ️ Group notes**\n• **Star Ollama Prompt Helper** — turns a short idea into a rich Krea 2 prompt using a local Ollama LLM (server + model selectable). Skip it and type directly into CLIP Text Encode if you prefer.\n• **Preview Any** — shows the refined prompt text before encoding.\n• **CLIP Text Encode** — encodes the final prompt into conditioning."
      ],
      "color": "#432",
      "bgcolor": "#653"
    },
